{
  "version": 3,
  "configurePresets": [
    {
      "name": "zephyr-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "qemu_x86_64",
      "description": "Host-side smoke build for qemu_x86_64",
      "inherits": "zephyr-base",
      "cacheVariables": {
        "BOARD": "qemu_x86_64"
      }
    },
    {
      "name": "native_sim",
      "description": "Host-side smoke build for native_sim",
      "inherits": "zephyr-base",
      "cacheVariables": {
        "BOARD": "native_sim"
      }
    },
    {
      "name": "nucleo_h755zi_q",
      "description": "STM32H7 hardware build for nucleo_h755zi_q",
      "inherits": "zephyr-base",
      "cacheVariables": {
        "BOARD": "nucleo_h755zi_q/stm32h755xx/m7"
      }
    },
    {
      "name": "nrf54l15dk",
      "description": "Nordic nRF54L15DK hardware build",
      "inherits": "zephyr-base",
      "cacheVariables": {
        "BOARD": "nrf54l15dk/nrf54l15/cpuapp"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qemu_x86_64",
      "configurePreset": "qemu_x86_64"
    },
    {
      "name": "native_sim",
      "configurePreset": "native_sim"
    },
    {
      "name": "nucleo_h755zi_q",
      "configurePreset": "nucleo_h755zi_q"
    },
    {
      "name": "nrf54l15dk",
      "configurePreset": "nrf54l15dk"
    }
  ]
}